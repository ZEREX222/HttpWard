{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AppConfig",
  "description": "Combined configuration in memory: global + all loaded sites",
  "type": "object",
  "properties": {
    "global": {
      "$ref": "#/$defs/GlobalConfig"
    },
    "sites": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SiteConfig"
      }
    }
  },
  "required": [
    "global",
    "sites"
  ],
  "$defs": {
    "GlobalConfig": {
      "description": "Global application configuration (loaded from httpward.yaml)\nInherits all fields from SiteConfig plus global-specific settings",
      "type": "object",
      "properties": {
        "domain": {
          "description": "Primary domain name (used for SNI matching & logging)",
          "type": "string",
          "default": ""
        },
        "domains": {
          "description": "Additional domain names / aliases",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "listeners": {
          "description": "Network listeners (bind address + port + optional TLS)",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Listener"
          },
          "default": []
        },
        "routes": {
          "description": "Global routing rules (executed before site-level routes)",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Route"
          },
          "default": []
        },
        "log": {
          "description": "Logging configuration",
          "$ref": "#/$defs/LogConfig",
          "default": {
            "level": ""
          }
        },
        "sites_enabled": {
          "description": "Path to directory with per-site .yaml / .yml files",
          "type": "string",
          "default": ""
        },
        "strategy": {
          "description": "Default strategy for all domains and routes",
          "type": "string",
          "default": "default"
        },
        "strategies": {
          "description": "Global strategy definitions",
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/MiddlewareConfig"
            }
          },
          "default": {}
        }
      },
      "additionalProperties": false
    },
    "Listener": {
      "type": "object",
      "properties": {
        "host": {
          "description": "Bind address (default: 0.0.0.0)",
          "type": "string",
          "default": "0.0.0.0"
        },
        "port": {
          "description": "TCP port",
          "type": "integer",
          "format": "uint16",
          "minimum": 0,
          "maximum": 65535,
          "default": 0
        },
        "tls": {
          "description": "Optional TLS configuration",
          "anyOf": [
            {
              "$ref": "#/$defs/Tls"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      }
    },
    "Tls": {
      "type": "object",
      "properties": {
        "self_signed": {
          "type": "boolean",
          "default": false
        },
        "cert": {
          "type": "string",
          "default": ""
        },
        "key": {
          "type": "string",
          "default": ""
        }
      }
    },
    "Route": {
      "description": "Single routing rule — proxy / static / redirect",
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "match": {
              "$ref": "#/$defs/Match"
            },
            "backend": {
              "type": "string"
            },
            "strategy": {
              "anyOf": [
                {
                  "$ref": "#/$defs/StrategyRef"
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            },
            "strategies": {
              "type": [
                "object",
                "null"
              ],
              "additionalProperties": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/MiddlewareConfig"
                }
              },
              "default": null
            }
          },
          "required": [
            "match",
            "backend"
          ]
        },
        {
          "type": "object",
          "properties": {
            "match": {
              "$ref": "#/$defs/Match"
            },
            "static_dir": {
              "type": "string"
            },
            "strategy": {
              "anyOf": [
                {
                  "$ref": "#/$defs/StrategyRef"
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            },
            "strategies": {
              "type": [
                "object",
                "null"
              ],
              "additionalProperties": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/MiddlewareConfig"
                }
              },
              "default": null
            }
          },
          "required": [
            "match",
            "static_dir"
          ]
        },
        {
          "type": "object",
          "properties": {
            "match": {
              "$ref": "#/$defs/Match"
            },
            "redirect": {
              "$ref": "#/$defs/Redirect"
            },
            "strategy": {
              "anyOf": [
                {
                  "$ref": "#/$defs/StrategyRef"
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            },
            "strategies": {
              "type": [
                "object",
                "null"
              ],
              "additionalProperties": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/MiddlewareConfig"
                }
              },
              "default": null
            }
          },
          "required": [
            "match",
            "redirect"
          ]
        }
      ]
    },
    "Match": {
      "type": "object",
      "properties": {
        "path": {
          "description": "Using matchit library https://github.com/ibraheemdev/matchit",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "path_regex": {
          "description": "Using basic regexp. Please use path if it's possible.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    },
    "StrategyRef": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/Strategy"
        }
      ]
    },
    "Strategy": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "middleware": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MiddlewareConfig"
          },
          "default": []
        }
      },
      "required": [
        "name"
      ]
    },
    "MiddlewareConfig": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "Named": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "config": true
              },
              "required": [
                "name",
                "config"
              ]
            }
          },
          "required": [
            "Named"
          ],
          "additionalProperties": false
        }
      ]
    },
    "Redirect": {
      "type": "object",
      "properties": {
        "to": {
          "type": "string"
        },
        "code": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0,
          "maximum": 65535,
          "default": 301
        }
      },
      "required": [
        "to"
      ]
    },
    "LogConfig": {
      "type": "object",
      "properties": {
        "level": {
          "description": "Logging level (\"trace\" | \"debug\" | \"info\" | \"warn\" | \"error\")",
          "type": "string",
          "default": "warn"
        }
      }
    },
    "SiteConfig": {
      "description": "Configuration for one virtual host / site",
      "type": "object",
      "properties": {
        "domain": {
          "description": "Primary domain name (used for SNI matching & logging)",
          "type": "string",
          "default": ""
        },
        "domains": {
          "description": "Additional domain names / aliases",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "listeners": {
          "description": "Optional site-specific listeners (overrides global listeners)",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Listener"
          },
          "default": []
        },
        "routes": {
          "description": "Site-level routing rules",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Route"
          },
          "default": []
        },
        "strategy": {
          "description": "Site-specific strategy (overrides global default)",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "strategies": {
          "description": "Site-specific strategy definitions",
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/MiddlewareConfig"
            }
          },
          "default": {}
        }
      },
      "additionalProperties": false
    }
  }
}